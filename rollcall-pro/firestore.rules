// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: participants
// Fields:
//   - name: string (required)
//   - mobileLast4: string (required, 4 digits)
//
// Collection: sessions
// Fields:
//   - name: string (required)
//   - date: string (required, YYYY-MM-DD)
//   - isActive: bool (required)
//   - createdAt: number (required)
//
// Subcollection: sessions/{sessionId}/attendance
// Fields:
//   - sessionId: string (required)
//   - participantId: string (required)
//   - participantName: string (required)
//   - confirmedAt: number (required)
//   - date: string (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "phish.econ@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidParticipant(data) {
      return data.keys().hasAll(['name', 'mobileLast4']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.mobileLast4 is string && data.mobileLast4.matches("^\\d{4}$");
    }

    function isValidSession(data) {
      return data.keys().hasAll(['name', 'date', 'isActive', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.date is string && data.date.matches("^\\d{4}-\\d{2}-\\d{2}$") &&
             data.isActive is bool &&
             data.createdAt is number;
    }

    function isValidAttendance(data) {
      return data.keys().hasAll(['sessionId', 'participantId', 'participantName', 'confirmedAt', 'date']) &&
             data.sessionId is string &&
             data.participantId is string &&
             data.participantName is string && data.participantName.size() > 0 &&
             data.confirmedAt is number &&
             data.date is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /participants/{participantId} {
      allow read: if true; // Kiosk needs to lookup participants by last 4 digits
      allow write: if isAdmin();
    }

    match /sessions/{sessionId} {
      allow read: if true;
      allow write: if isAdmin();

      match /attendance/{recordId} {
        allow read: if true;
        allow create: if isValidAttendance(request.resource.data);
        allow update, delete: if isAdmin();
      }
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAdmin();
    }
  }
}
