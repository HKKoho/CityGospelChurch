# GEMINI_API_KEY: Required for Gemini AI API calls (server-side only).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Supabase: Required for database and authentication.
# For hosted Supabase: get these from supabase.com > Project Settings > API
# For self-hosted Supabase: use your Docker instance URL and anon key
VITE_SUPABASE_URL="https://xxxx.supabase.co"
VITE_SUPABASE_ANON_KEY="eyJhbGci..."
